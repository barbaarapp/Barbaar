{
  "entities": {
    "profiles": {
      "title": "User Profile",
      "description": "Stores user-specific data like points, level, and preferences.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The user's unique ID from Firebase Auth." },
        "name": { "type": "string", "description": "Display name of the user." },
        "avatar_url": { "type": "string", "description": "URL to the user's avatar image." },
        "level": { "type": "integer", "description": "Current level of the user." },
        "experience": { "type": "integer", "description": "Current experience points." },
        "next_level_exp": { "type": "integer", "description": "Experience points needed for next level." },
        "streak": { "type": "integer", "description": "Current daily streak." },
        "journal_streak": { "type": "integer", "description": "Current journal streak." },
        "mood_streak": { "type": "integer", "description": "Current mood streak." },
        "points": { "type": "integer", "description": "Total XP points." },
        "sabr_points": { "type": "integer", "description": "Points for good activities/patience." },
        "sabr_points_today": { "type": "integer", "description": "Sabr points earned today." },
        "growth_score": { "type": "integer", "description": "Holistic growth score (0-100)." },
        "focus_time_total": { "type": "integer", "description": "Total focus time in seconds." },
        "focus_time_today": { "type": "integer", "description": "Focus time today in seconds." },
        "daily_wins": { "type": "integer", "description": "Count of daily wins." },
        "total_wins": { "type": "integer", "description": "Total wins across all time." },
        "mood": { "type": "string", "description": "Last recorded mood." },
        "has_checked_in": { "type": "boolean", "description": "Whether the user checked in today." },
        "mood_log_count_today": { "type": "integer", "description": "Number of mood logs today." },
        "last_mood_log_date": { "type": "string", "description": "ISO date of last mood log." },
        "last_active_date": { "type": "string", "description": "Last date the user was active." },
        "last_reward_date": { "type": "string", "description": "For variable rewards." },
        "last_login_date": { "type": "string", "description": "Daily welcome reward." },
        "last_journal_date": { "type": "string", "description": "Daily first journal bonus." },
        "unlocked_features": { "type": "array", "items": { "type": "string" }, "description": "List of features unlocked by the user." },
        "achievements": { "type": "array", "items": { "type": "string" }, "description": "List of IDs of unlocked badges." },
        "language": { "type": "string", "enum": ["en", "so"] },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "completed_resources": { "type": "array", "items": { "type": "string" } },
        "saved_resources": { "type": "array", "items": { "type": "string" } },
        "encouragements_received": { "type": "integer" },
        "total_word_count": { "type": "integer" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "mood_logs": {
      "title": "Mood Log",
      "description": "A record of a user's mood at a specific time.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "mood": { "type": "string", "enum": ["very-sad", "sad", "neutral", "happy", "very-happy"] },
        "note": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "date", "mood"]
    },
    "tasks": {
      "title": "Task",
      "description": "A productivity task created by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "title": { "type": "string" },
        "time": { "type": "string" },
        "duration": { "type": "string" },
        "completed": { "type": "boolean" },
        "completed_at": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "due_date": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "focus_time_spent": { "type": "integer" }
      },
      "required": ["user_id", "title"]
    },
    "journal_entries": {
      "title": "Journal Entry",
      "description": "A daily reflection entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "content": { "type": "string" },
        "mood": { "type": "string" },
        "date": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "content", "date"]
    },
    "nasasho": {
      "title": "Nasasho Content",
      "description": "Audio and video content for relaxation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["Podcast", "Quran", "Nature", "Sleep"] },
        "audioUrl": { "type": "string" },
        "embedUrl": { "type": "string", "description": "Google Drive or other iframe embed URL." },
        "duration": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "reciter": { "type": "string" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "duration", "image"]
    },
    "challenges": {
      "title": "Discipline Challenge",
      "description": "A pre-designed or custom discipline challenge.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "durationDays": { "type": "integer" },
        "tasks": { "type": "array", "items": { "type": "object" } },
        "category": { "type": "string", "enum": ["discipline", "health", "mindset", "productivity"] },
        "image": { "type": "string" },
        "isCustom": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "participantsCount": { "type": "integer" },
        "published": { "type": "boolean" },
        "terms": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "description", "durationDays", "tasks", "category"]
    },
    "user_challenges": {
      "title": "User Challenge Progress",
      "description": "Tracks a user's progress in a specific challenge.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "challengeId": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "completed", "failed"] },
        "currentDay": { "type": "integer" },
        "dailyProgress": { "type": "object" },
        "streak": { "type": "integer" },
        "lastCheckInDate": { "type": "string" }
      },
      "required": ["user_id", "challengeId", "startDate", "endDate", "status"]
    },
    "chat_rooms": {
      "title": "Chat Room",
      "description": "A chat session between a user and the Barbaar team.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "active", "closed"] },
        "created_at": { "type": "string", "format": "date-time" },
        "last_message_at": { "type": "string", "format": "date-time" },
        "assigned_team_member_id": { "type": "string" },
        "assigned_team_member_name": { "type": "string" }
      },
      "required": ["user_id", "status", "created_at"]
    },
    "chat_messages": {
      "title": "Chat Message",
      "description": "A message within a chat room.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "room_id": { "type": "string" },
        "user_id": { "type": "string", "description": "The UID of the user who owns the chat room (for secure listing)." },
        "sender_id": { "type": "string" },
        "sender_name": { "type": "string" },
        "sender_type": { "type": "string", "enum": ["user", "team"] },
        "text": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["room_id", "user_id", "sender_id", "sender_type", "text", "created_at"]
    },
    "therapists": {
      "title": "Therapist Profile",
      "description": "A professional therapist profile with bio and availability.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "bio": { "type": "string" },
        "image": { "type": "string" },
        "rate": { "type": "string" },
        "rating": { "type": "number" },
        "availableSlots": { "type": "array", "items": { "type": "string" } },
        "published": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "specialty", "bio", "image", "rate", "availableSlots"]
    },
    "bookings": {
      "title": "Therapy Booking",
      "description": "A session booking record between a user and a therapist.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "therapistId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "slot": { "type": "string" },
        "demographics": { "type": "object" },
        "evcNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["therapistId", "userId", "slot", "status", "createdAt"]
    },
    "notifications": {
      "title": "Notification",
      "description": "App notification for achievement, reminder or encouragement.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "type": { "type": "string", "enum": ["achievement", "reminder", "encouragement"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "icon": { "type": "string" }
      },
      "required": ["user_id", "type", "title", "content", "timestamp", "read"]
    },
    "resources": {
      "title": "Learning Resource",
      "description": "Educational content for wellness and growth.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["Course", "Book Summary", "Article", "Audio Book", "Scientific Paper", "Podcast"] },
        "category": { "type": "string", "enum": ["Wellness", "Growth", "Productivity", "Habits"] },
        "image": { "type": "string" },
        "duration": { "type": "string" },
        "content": { "type": "string" },
        "pages": { "type": "array", "items": { "type": "string" } },
        "author": { "type": "string" },
        "language": { "type": "string", "enum": ["en", "so", "ar"] },
        "audioUrl": { "type": "string" },
        "embedUrl": { "type": "string" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "category", "image", "duration"]
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "profiles",
      "description": "User profile documents."
    },
    "/mood_logs/{logId}": {
      "schema": "mood_logs",
      "description": "User mood logs."
    },
    "/tasks/{taskId}": {
      "schema": "tasks",
      "description": "Individual task documents."
    },
    "/journal_entries/{entryId}": {
      "schema": "journal_entries",
      "description": "User journal entries."
    },
    "/nasasho/{nasashoId}": {
      "schema": "nasasho",
      "description": "Nasasho relaxation content."
    },
    "/challenges/{challengeId}": {
      "schema": "challenges",
      "description": "Available discipline challenges."
    },
    "/user_challenges/{userChallengeId}": {
      "schema": "user_challenges",
      "description": "User progress in challenges."
    },
    "/chat_rooms/{roomId}": {
      "schema": "chat_rooms",
      "description": "Chat rooms for support."
    },
    "/chat_messages/{messageId}": {
      "schema": "chat_messages",
      "description": "Messages within chat rooms."
    },
    "/therapists/{therapistId}": {
      "schema": "therapists",
      "description": "Registered therapist profiles."
    },
    "/bookings/{bookingId}": {
      "schema": "bookings",
      "description": "Session booking records."
    },
    "/notifications/{notificationId}": {
      "schema": "notifications",
      "description": "App notifications."
    },
    "/resources/{resourceId}": {
      "schema": "resources",
      "description": "Educational resources."
    }
  }
}
