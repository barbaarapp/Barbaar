{
  "version": "1",
  "routes": [
    {
      "pattern": "/api/*",
      "zone_name": "barbaarapp.com"
    }
  ],
  "build": {
    "command": "npm run build",
    "cwd": "./",
    "destination": "dist"
  },
  "compatibility_date": "2024-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  }
}
