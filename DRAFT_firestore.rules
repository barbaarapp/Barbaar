rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == "qaalidibrahim.996@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===============================================================
    // Validation Blueprints (The Anti-Update-Gap)
    // ===============================================================

    function isValidProfile(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('avatar_url' in data) || (data.avatar_url is string && data.avatar_url.size() < 500)) &&
             (!('level' in data) || data.level is int) &&
             (!('experience' in data) || data.experience is int) &&
             (!('points' in data) || data.points is int) &&
             (!('sabr_points' in data) || data.sabr_points is int) &&
             (!('language' in data) || data.language in ['en', 'so']) &&
             (!('updated_at' in data) || data.updated_at == request.time);
    }

    function isValidTask(data) {
      return data.user_id == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             (!('completed' in data) || data.completed is bool) &&
             (!('priority' in data) || data.priority in ['low', 'medium', 'high']) &&
             (!('created_at' in data) || data.created_at == request.time);
    }

    function isValidJournalEntry(data) {
      return data.user_id == request.auth.uid &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.date is string && data.date.size() < 50 &&
             (!('created_at' in data) || data.created_at == request.time);
    }

    function isValidMoodLog(data) {
      return data.user_id == request.auth.uid &&
             data.date is string && data.date.size() < 50 &&
             data.mood in ['very-sad', 'sad', 'neutral', 'happy', 'very-happy'] &&
             (!('created_at' in data) || data.created_at == request.time);
    }

    function isValidBooking(data) {
      return data.userId == request.auth.uid &&
             data.status in ['pending', 'confirmed', 'cancelled'] &&
             data.evcNumber is string && data.evcNumber.size() < 20 &&
             (!('createdAt' in data) || data.createdAt == request.time);
    }

    function isValidChallenge(data) {
      return data.title is string && data.title.size() < 100 &&
             data.description is string && data.description.size() < 1000 &&
             data.durationDays is int && data.durationDays > 0 &&
             data.tasks is list && data.tasks.size() < 50 &&
             data.category in ['discipline', 'health', 'mindset', 'productivity'];
    }

    function isValidUserChallenge(data) {
      return data.user_id == request.auth.uid &&
             data.status in ['active', 'completed', 'failed'] &&
             (!('currentDay' in data) || data.currentDay is int);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Profiles: Owner-only private PII, public basic info? 
    // App seems to allow all users to read other profiles (list)? 
    // "allow read: if isAuthenticated();" - Bad. 
    // Profiles should only be readable by self or admin.
    match /profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Prevent scraping
      allow create: if isOwner(userId) && isValidProfile(incoming()) && incoming().id == userId;
      allow update: if (isOwner(userId) && isValidProfile(incoming()) && incoming().id == existing().id) || isAdmin();
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && (existing().user_id == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (request.query.limit <= 100 && resource.data.user_id == request.auth.uid);
      allow create: if isValidId(taskId) && isValidTask(incoming());
      allow update: if isOwner(existing().user_id) && isValidTask(incoming()) && incoming().user_id == existing().user_id;
      allow delete: if isOwner(existing().user_id) || isAdmin();
    }

    match /journal_entries/{entryId} {
      allow get: if isSignedIn() && (existing().user_id == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isValidId(entryId) && isValidJournalEntry(incoming());
      allow update: if isOwner(existing().user_id) && isValidJournalEntry(incoming()) && incoming().user_id == existing().user_id;
      allow delete: if isOwner(existing().user_id) || isAdmin();
    }

    match /mood_logs/{logId} {
      allow get: if isSignedIn() && (existing().user_id == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isValidId(logId) && isValidMoodLog(incoming());
      allow update: if isOwner(existing().user_id) && isValidMoodLog(incoming()) && incoming().user_id == existing().user_id;
      allow delete: if isOwner(existing().user_id) || isAdmin();
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isAdmin(); // Users should get by ID or filter. App doesn't seem to list all bookings for users.
      allow create: if isValidId(bookingId) && isValidBooking(incoming());
      allow update: if isAdmin() || (isOwner(existing().userId) && isValidBooking(incoming()) && incoming().userId == existing().userId);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (existing().user_id == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isAdmin(); // Notifications are usually system-generated
      allow update: if isOwner(existing().user_id) && incoming().read == true && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(existing().user_id) || isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if (resource != null && resource.data.published == true) || isAdmin();
      allow write: if isAdmin();
    }

    match /therapists/{therapistId} {
      allow read: if (resource != null && resource.data.published == true) || isAdmin();
      allow write: if isAdmin();
    }

    match /nasasho/{nasashoId} {
      allow read: if (resource != null && resource.data.published == true) || isAdmin();
      allow write: if isAdmin();
    }

    match /challenges/{challengeId} {
      allow read: if isSignedIn();
      allow create: if isValidId(challengeId) && isValidChallenge(incoming());
      allow update: if isAdmin() || (isOwner(existing().createdBy) && isValidChallenge(incoming()));
      allow delete: if isAdmin() || isOwner(existing().createdBy);
    }

    match /user_challenges/{userChallengeId} {
      allow get: if isOwner(existing().user_id) || isAdmin();
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isValidId(userChallengeId) && isValidUserChallenge(incoming());
      allow update: if isOwner(existing().user_id) && isValidUserChallenge(incoming());
      allow delete: if isOwner(existing().user_id) || isAdmin();
    }

    match /chat_rooms/{roomId} {
      allow get: if isOwner(existing().user_id) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create: if isValidId(roomId) && incoming().user_id == request.auth.uid;
      allow update: if isAdmin() || (isOwner(existing().user_id) && incoming().status == 'closed');
    }

    match /chat_messages/{messageId} {
      allow get: if isSignedIn() && (
        get(/databases/$(database)/documents/chat_rooms/$(existing().room_id)).data.user_id == request.auth.uid || isAdmin()
      );
      allow list: if isSignedIn() && (
        get(/databases/$(database)/documents/chat_rooms/$(request.query.limit <= 100 && resource.data.room_id)).data.user_id == request.auth.uid || isAdmin()
      );
      allow create: if isValidId(messageId) && (
        (incoming().sender_type == 'user' && incoming().sender_id == request.auth.uid && get(/databases/$(database)/documents/chat_rooms/$(incoming().room_id)).data.user_id == request.auth.uid) ||
        (incoming().sender_type == 'team' && isAdmin())
      );
    }
  }
}
